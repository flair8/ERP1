@page "/login"
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<main class="auth-page">
    <section class="auth-card">
        <a class="auth-brand" asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl"><span class="brand-icon"><i class="bi bi-grid-1x2-fill" aria-hidden="true"></i></span><span><strong>ERP1</strong><small>Sign in to your admin workspace.</small></span></a>
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
        <form class="needs-validation" novalidate method="POST">
            <div class="mb-4">
                <p class="eyebrow mb-1">Secure Access</p>
                <h1 class="h3 mb-1">Login</h1>
                <p class="text-muted mb-0">Sign in to your admin workspace.</p>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Email address</label>
                <input asp-for="Input.Email" class="form-control" id="loginEmail" type="email" required>
                <span asp-validation-for="Input.Email" class="invalid-feedback"></span>
            </div>
            <div class="mb-3">
                <div class="d-flex justify-content-between">
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <a class="small fw-semibold" asp-page="./ForgotPassword">Forgot?</a>
                </div>
                <input asp-for="Input.Password" class="form-control" id="loginPassword" type="password" minlength="6" required>
                <span asp-validation-for="Input.Password" class="invalid-feedback">Password must be at least 6 characters.</span>
            </div>
            <div class="form-check mb-4">
                <input class="form-check-input" type="checkbox" id="rememberMe">
                <label class="form-check-label" for="rememberMe">Remember me</label>
            </div>
            <button class="btn btn-primary w-100" type="submit"><i class="bi bi-box-arrow-in-right" aria-hidden="true"></i> Sign In</button>
        </form>

        <div class="auth-footer">New here? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create an account</a></div>
    </section>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
